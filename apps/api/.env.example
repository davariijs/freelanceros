PORT=3000
NODE_ENV=development
JWT_SECRET=your_super_secure_jwt_access_token_secret_key
REFRESH_SECRET=your_super_secure_jwt_refresh_token_secret_key
JWT_EXPIRES_IN=24h
REFRESH_EXPIRES_IN=7d
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/freelanceos?schema=public
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id_for_backend
EMAIL_USER=your_smtp_email_address_for_sending_verification_codes
EMAIL_PASS=your_smtp_email_app_password
CRON_SECRET=your_secure_cron_webhook_secret_key