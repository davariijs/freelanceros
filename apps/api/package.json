{
  "name": "@freelanceos/api",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/server.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register src/server.ts",
    "build": "npx esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --external:pg-native --external:@prisma/client",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "test": "jest",
    "test:unit": "jest",
    "test:e2e": "jest --config jest-e2e.config.js"
  },
  "dependencies": {
    "@freelanceos/database": "workspace:*",
    "@prisma/client": "7.8.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.2",
    "express-async-errors": "^3.1.1",
    "google-auth-library": "^10.9.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "node-cron": "^4.6.0",
    "nodemailer": "^9.0.3",
    "pino": "^9.14.0",
    "pino-http": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@freelanceos/eslint-config": "workspace:*",
    "@freelanceos/ts-config": "workspace:*",
    "@playwright/test": "^1.61.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.43",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.10",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
