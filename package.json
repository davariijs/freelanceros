{
  "name": "freelanceos",
  "private": true,
  "scripts": {
    "dev": "pnpm --recursive --parallel dev",
    "build": "turbo run build --no-daemon",
    "lint": "turbo run lint --no-daemon",
    "format": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "test": "pnpm --recursive test",
    "test:unit": "pnpm --recursive test:unit",
    "test:e2e": "pnpm --recursive test:e2e"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "turbo": "^2.9.18",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  }
}
